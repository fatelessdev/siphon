# Siphon Environment Configuration
# Copy to .env and fill in your values for local development.

# Twitter/X Authentication (required)
# Get these from your browser's cookies on x.com:
#   auth_token: the auth_token cookie value
#   ct0: the ct0 cookie value
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
# Optional: paste the full browser Cookie header to better match twitter-cli browser-cookie mode.
# Must include auth_token and ct0 when set.
TWITTER_COOKIE_STRING=

# PostgreSQL Database URL (required)
# Neon direct connection (NOT pooled -pooler):
DATABASE_URL=postgresql://user:password@host/siphon?sslmode=require

# Optional configuration
SIPHON_CACHE_DIR=.siphon-cache
SIPHON_LOG_LEVEL=INFO
SCRAPE_DEFAULT_COUNT=30
SIPHON_DEBUG_HTTP=false
